<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - UniversityPayroll</title>
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">UniversityPayroll</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav" aria-controls="navbarNav"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Designation" asp-action="Index">Designations</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="LeaveType" asp-action="Index">Leave Types</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="LeaveEntitlement" asp-action="Index">Entitlements</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="SalaryStructure" asp-action="Index">Salary Structures</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="TaxSlab" asp-action="Index">Tax Slabs</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Employee" asp-action="Index">Employees</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="LeaveApproval" asp-action="Index">Leave Approval</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="SalarySlip" asp-action="Index">Salary Slips</a></li>
                    }
                    @if (User.IsInRole("Employee"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="LeaveRequest" asp-action="Index">My Leaves</a></li>
                    }
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Profile" asp-action="Index">My Profile</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @await Html.PartialAsync("_LoginPartial")
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">&copy; @(DateTime.Now.Year) UniversityPayroll</div>
    </footer>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
