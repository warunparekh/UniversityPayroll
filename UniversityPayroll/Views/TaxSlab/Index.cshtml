@model IEnumerable<UniversityPayroll.Models.TaxSlab>
@{
    ViewData["Title"] = "Tax Slabs";
}
<h2>Tax Slabs</h2>
<p><a asp-action="Create" class="btn btn-success">New</a></p>
<table class="table table-striped">
    <thead>
        <tr><th>Min Income</th><th>Max Income</th><th>Rate (%)</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.MinAnnualIncome</td>
                <td>@t.MaxAnnualIncome</td>
                <td>@t.Rate</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@t.Id" method="post" style="display:inline">
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
