@model UniversityPayroll.Models.TaxSlab
@{
    ViewData["Title"] = "Create Tax Slab";
}
<h2>Create Tax Slab</h2>
<form asp-action="Create">
    <div class="mb-3">
        <label asp-for="MinAnnualIncome" class="form-label"></label>
        <input asp-for="MinAnnualIncome" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="MaxAnnualIncome" class="form-label"></label>
        <input asp-for="MaxAnnualIncome" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Rate" class="form-label"></label>
        <input asp-for="Rate" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
