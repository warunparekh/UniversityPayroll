@model UniversityPayroll.Models.SalaryStructure
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Create Salary Structure";
}
<h2>@ViewData["Title"]</h2>
<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Designation</label>
        <select asp-for="DesignationId" asp-items="ViewBag.Designations" class="form-select">
            <option value="">-- select --</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Basic" class="form-label"></label>
        <input asp-for="Basic" class="form-control" />
    </div>

    <h5>Allowances</h5>
    @for (int i = 0; i < Model.Allowances.Count; i++)
    {
        <div class="row mb-2">
            <div class="col">
                <input asp-for="Allowances[@i].Name" class="form-control" placeholder="Name" />
            </div>
            <div class="col">
                <input asp-for="Allowances[@i].Amount" class="form-control" placeholder="Amount" />
            </div>
        </div>
    }

    <h5>Deductions</h5>
    @for (int i = 0; i < Model.Deductions.Count; i++)
    {
        <div class="row mb-2">
            <div class="col">
                <input asp-for="Deductions[@i].Name" class="form-control" placeholder="Name" />
            </div>
            <div class="col">
                <input asp-for="Deductions[@i].Amount" class="form-control" placeholder="Amount" />
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary mt-3">Save</button>
</form>
