@model IEnumerable<UniversityPayroll.Models.SalaryStructure>
@{
    ViewData["Title"] = "Salary Structures";
}
<h2>Salary Structures</h2>
<p><a asp-action="Create" class="btn btn-success">New</a></p>
<table class="table table-striped">
    <thead>
        <tr><th>Designation</th><th>Basic</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.DesignationId</td>
                <td>@s.Basic</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@s.Id" method="post" style="display:inline">
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
