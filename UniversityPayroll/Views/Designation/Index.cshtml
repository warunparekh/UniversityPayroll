@model IEnumerable<UniversityPayroll.Models.DesignationIndexItem>
@{
    ViewData["Title"] = "Designations";
}
<h2>@ViewData["Title"]</h2>
<p><a asp-action="Create" class="btn btn-success">New Designation</a></p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Entitlements (Type:Quota)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.Name</td>
                <td>@string.Join(", ", d.Entitlements)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@d.Id" method="post" style="display:inline">
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
