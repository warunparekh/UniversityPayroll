@model IEnumerable<UniversityPayroll.Models.LeaveType>
<h2>Leave Types</h2>
<p><a asp-action="Create" class="btn btn-success">New</a></p>
<table class="table">
    <thead><tr><th>Name</th><th></th></tr></thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@t.Id" method="post" style="display:inline">
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
