@{
    ViewData["Title"] = "Generate Salary Slips";
}
<h2>Generate Salary Slips</h2>
<form asp-action="Generate" method="post">
    <div class="mb-3">
        <label>Month</label>
        <input name="month" type="number" min="1" max="12" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Year</label>
        <input name="year" type="number" min="2000" max="2100" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Generate</button>
</form>
