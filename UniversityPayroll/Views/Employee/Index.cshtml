@model IEnumerable<UniversityPayroll.Controllers.EmployeeController.ListModel>
@{
    ViewData["Title"] = "Employees";
}
<h2>Employees</h2>
<p><a asp-action="Create" class="btn btn-success">New Employee</a></p>
<table class="table table-striped">
    <thead>
        <tr><th>Name</th><th>Email</th><th>Designation</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.FullName</td>
                <td>@e.Email</td>
                <td>@e.Designation</td>
                <td>
                    <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@e.Id" method="post" style="display:inline">
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
