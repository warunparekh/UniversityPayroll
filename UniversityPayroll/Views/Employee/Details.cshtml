@{
    ViewData["Title"] = "Employee Details";
}
<h2>Employee Details</h2>
<ul class="list-group">
    <li class="list-group-item"><strong>Name:</strong> @ViewBag.Name</li>
    <li class="list-group-item"><strong>Email:</strong> @ViewBag.Email</li>
    <li class="list-group-item"><strong>Designation:</strong> @ViewBag.Designation</li>
</ul>
