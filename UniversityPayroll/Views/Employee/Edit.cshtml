@model UniversityPayroll.Controllers.EmployeeController.EditModel
@{
    ViewData["Title"] = "Edit Employee";
}
<h2>Edit Employee</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="DesignationId" class="form-label">Designation</label>
        <select asp-for="DesignationId" class="form-select"
                asp-items="@(new SelectList(ViewBag.Designations, "Id", "Name", Model.DesignationId))">
            <option value="">-- select --</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Update</button>
</form>
